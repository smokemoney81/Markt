# Konfiguration für das Deployment. Kopieren nach .env und anpassen:
#   cp .env.example .env

# --- Pflicht ---
# Deine Google-Cloud-Projekt-ID (Cloud Console → oben in der Projektauswahl).
PROJECT_ID=mein-gcp-projekt

# --- Modell ---
# Aus dem Ollama-Katalog:   llama3.2:3b | qwen2.5:7b | gemma2:9b | minimax-m2
# Direkt von Hugging Face:  hf.co/<user>/<repo-GGUF>:<Quant>
#   z. B. hf.co/bartowski/Llama-3.2-3B-Instruct-GGUF:Q4_K_M
OLLAMA_MODEL=llama3.2:3b

# Nur für private/gated Modelle von Hugging Face nötig (Read-Token).
# HF_TOKEN=hf_xxx

# --- Cloud Run (deploy-cloudrun.sh) ---
REGION=us-central1
SERVICE=ollama
GPU_TYPE=nvidia-l4
MEMORY=16Gi
CPU=4
# true = Dienst ist öffentlich ohne Auth erreichbar (Vorsicht!)
ALLOW_UNAUTH=false

# --- Compute Engine (deploy-gce.sh) ---
ZONE=us-central1-a
VM_NAME=ollama-vm
MACHINE_TYPE=g2-standard-8
GPU_COUNT=1
DISK_SIZE=200
# true = Firewall für Port 11434 öffnen (sonst nur per SSH-Tunnel)
OPEN_FIREWALL=false
