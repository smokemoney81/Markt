# Supabase – findest du im Supabase Dashboard unter: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key

# Nur serverseitig (Münz-Meister-Ökonomie): "service_role"-Key aus demselben
# Menü. GEHEIM – niemals mit NEXT_PUBLIC_ ausliefern oder committen. Nur nötig,
# wenn das Spiel serverautoritativ laufen soll (empfohlen für Monetarisierung).
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key

# Nur für lokale Tests des Shops OHNE echten Zahlungsanbieter. Wenn 'true',
# werden Käufe ohne Zahlungsnachweis gutgeschrieben (provider='test').
# NIEMALS in Produktion aktivieren – sonst gibt es Gegenstände geschenkt.
# PAYMENTS_TEST_MODE=true

# Stripe (echter Kauf-Flow). Beide Keys sind GEHEIM (server-only).
# STRIPE_SECRET_KEY: Stripe Dashboard → Developers → API keys.
# STRIPE_WEBHOOK_SECRET: Signing-Secret des Webhook-Endpoints
#   (/api/spiel/stripe-webhook), Event 'checkout.session.completed'.
# STRIPE_SECRET_KEY=sk_live_oder_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Öffentliche Basis-URL für Stripe-Redirects (Fallback: Request-Origin).
# NEXT_PUBLIC_APP_URL=https://deine-domain.de
