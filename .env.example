# Supabase – findest du im Supabase Dashboard unter: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key

# Nur serverseitig (Münz-Meister-Ökonomie): "service_role"-Key aus demselben
# Menü. GEHEIM – niemals mit NEXT_PUBLIC_ ausliefern oder committen. Nur nötig,
# wenn das Spiel serverautoritativ laufen soll (empfohlen für Monetarisierung).
SUPABASE_SERVICE_ROLE_KEY=dein-service-role-key
